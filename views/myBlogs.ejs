<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>My Blogs</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <%- include('./partials/nav') %>

    <div class="container py-4">

        <!-- Page Heading -->
        <div class="mb-4">
            <h1 class="fw-bold">My Blogs</h1>
            <p class="text-muted">
                View all the blogs you've published.
            </p>
        </div>

        <% if (blogs.length === 0) { %>

            <!-- Empty State -->
            <div class="text-center py-5">
                <h2 class="fw-bold mb-3">
                    No Blogs Yet 📖
                </h2>
                <p class="text-muted mb-4">
                    You haven't published any blogs yet.
                    Start sharing your thoughts with the world.
                </p>
                <a
                    href="/blog/add-new"
                    class="btn btn-primary btn-lg"
                >
                    Create Your First Blog
                </a>
            </div>

        <% } else { %>

            <!-- Blog Cards -->
            <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4">
                <% blogs.forEach(blog => { %>
                    <div class="col">
                        <div
                            class="card blog-card h-100 shadow-sm"
                        >
                            <img
                                src="<%= blog.coverImageURL %>"
                                class="card-img-top blog-image"
                                alt="<%= blog.title %>"
                            >
                            <div class="card-body d-flex flex-column">
                                <h5 
                                    class="card-title blog-title"
                                    data-bs-toggle="tooltip"
                                    data-bs-placement="top"
                                    title="<%= blog.title %>"
                                >
                                    
                                    <%= blog.title %>
                                </h5>
                                <div class="mt-auto">
                                    <a
                                        href="/blog/<%= blog._id %>"
                                        class="btn btn-primary w-100"
                                    >
                                        View Blog
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                <% }) %>

            </div>

        <% } %>

    </div>

    <%- include('./partials/scripts') %>

</body>
</html>