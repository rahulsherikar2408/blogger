<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>

    <title><%= blog.title %></title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <%- include('./partials/nav') %>
    <div class="container py-5">
        <div class="mx-auto blog-container">

            <!-- Blog Title -->
            <h1 class="display-4 fw-bold mb-4">
                <%= blog.title %>
            </h1>

            <!-- Cover Image -->
            <img
                src="<%= blog.coverImageURL %>"
                class="img-fluid rounded-4 shadow-sm mb-4 w-100 blog-cover"
                alt="<%= blog.title %>"
            >

            <!-- Blog Body -->
            <div class="blog-content mb-5">
                <%= blog.body %>
            </div>

            <!-- Author -->
            <div class="card border-0 shadow-sm mb-5">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <img
                            src="<%= blog.createdBy.profileImage %>"
                            class="rounded-circle"
                            width="60"
                            height="60"
                        >
                        <div class="ms-3">
                            <h5 class="mb-1">
                                <%= blog.createdBy.fullName %>
                            </h5>
                            <small class="text-muted">
                                Author
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comments -->
            <h2 class="fw-bold mb-4">
                Comments (<%= comments.length %>)
            </h2>

            <% if(locals.user){ %>
                <div class="card shadow-sm border-0 mb-5">
                    <div class="card-body">
                        <form action="/blog/comment/<%= blog._id %>" method="POST">
                            <div class="mb-3">
                                <textarea
                                    class="form-control"
                                    rows="3"
                                    name="content"
                                    placeholder="Share your thoughts..."
                                    required
                                ></textarea>
                            </div>
                            <div class="text-end">
                                <button class="btn btn-primary px-4">
                                    Post Comment
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

            <% } %>

            <!-- Comments List -->
            <% if(comments.length === 0){ %>
                <div class="text-center text-muted py-5">
                    <h5>No comments yet.</h5>
                    <p>Be the first one to comment!</p>
                </div>
            <% } %>

            <% comments.forEach(comment => { %>
                <div class="card border-0 shadow-sm mb-3 comment-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <img
                                src="<%= comment.createdBy.profileImage %>"
                                class="rounded-circle"
                                width="50"
                                height="50"
                            >
                            <div class="ms-3">
                                <h6 class="mb-0">
                                    <%= comment.createdBy.fullName %>
                                </h6>
                                <small class="text-muted">
                                    Reader
                                </small>
                            </div>
                        </div>
                        <p class="mt-3 mb-0 comment-text">
                            <%= comment.content %>
                        </p>
                    </div>
                </div>

            <% }) %>

        </div>
    </div>

    <%- include('./partials/scripts') %>

</body>
</html>