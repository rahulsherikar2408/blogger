<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Blog</title>
</head>
<body>
    <%- include('./partials/nav') %>
    
    <div class="container mt-4">
        <div class="container"><h1><%= blog.title %></h1></div>
        <div class="container mt-3"><img src="<%= blog.coverImageURL %>" alt="Blog Image" class="img-fluid rounded"></div>
        <div class="container mt-3">
            <pre style="
                white-space: pre-wrap;
                word-wrap: break-word;
                overflow-wrap: break-word;
            "><%= blog.body %></pre>
        </div>
    </div>

    <div class="container mt-4">
        <img src="<%= blog.createdBy.profileImage %>" alt="Profile Img" width="50px">
        <%= blog.createdBy.fullName %>
    </div>

    <%- include('./partials/scripts') %>
</body>
</html>